msgid "Improvements:"
msgstr "Perbaikan:"

#: data/files.metainfo.xml.in.in:69
msgid ""
"The presence of undisplayed hidden files is indicated when there are no "
"visible files"
msgstr ""

#: data/files.metainfo.xml.in.in:70
msgid ""
"Undisplayed hidden files can temporarily be shown in an otherwise empty "
"folder"
msgstr ""

